---
import { type CollectionEntry, render } from "astro:content";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import BackButton from "@/components/BackButton.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";

import ShareLinks from "@/components/ShareLinks.astro";
import StructuredData from "@/components/StructuredData.astro";
import Tag from "@/components/Tag.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/site-config.js";
import postDetailsRerunUrl from "@/features/blog/client/postDetailsRerun.js?url";
import { getAdjacentEntries } from "@/features/blog/utils/getAdjacentEntries.js";
import { buildPostLayoutMetadata } from "@/features/blog/utils/postLayoutMetadata";
import { getPath } from "@/features/blog/utils/getPath";
import { countWords } from "@/features/blog/utils/readingMetrics";
import { getDisplayReadingTime } from "@/features/blog/utils/readingTimeText";
import { slugifyStr } from "@/utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  heroImage,
  layoutStyle,
} = post.data;

const { Content } = await render(post);
const readingTime = getDisplayReadingTime(post.data, post.body);
const { postPath, ogImage, layoutProps } = buildPostLayoutMetadata({
  post,
  siteTitle: SITE.title,
  siteBase: Astro.site,
  currentOrigin: Astro.url.origin,
  dynamicOgImageEnabled: SITE.dynamicOgImage,
});

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  path: getPath(id, filePath),
  title,
}));

const { prevEntry: prevPost, nextEntry: nextPost } = getAdjacentEntries(allPosts, postPath);

// Calculate word count for structured data
const wordCount = countWords(post.body ?? "");
---

<Layout {...layoutProps}>
  <StructuredData 
    type="BlogPosting" 
    data={{
      title,
      description,
      author,
      pubDatetime,
      modDatetime,
      url: Astro.url.href,
      ogImage,
      tags,
      wordCount,
      readingTime
    }} 
  />
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={[
      "mx-auto w-full max-w-3xl px-4 pb-12",
      { "mt-8": !SITE.showBackButton },
    ]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title)}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="flex items-center justify-between gap-4 mt-2 mb-6">
      <div class="flex items-center gap-3">
        <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
        {
          readingTime && (
            <>
              <span class="text-foreground/30">•</span>
              <span class="text-sm text-foreground/60">{readingTime}</span>
            </>
          )
        }
      </div>
      <EditPost class="max-sm:hidden" {hideEditPost} {post} />
    </div>
    <article id="article" class="mx-auto prose mt-6 max-w-3xl">
      {layoutStyle === "split" ? (
        <>
          {heroImage && (
            <img
              src={heroImage}
              alt=""
              class="w-full sm:w-1/2 float-left mr-6 sm:mr-8 mb-4 sm:mb-6 rounded-lg object-contain shadow-lg"
              loading="lazy"
            />
          )}
          <Content />
          <div class="clear-both"></div>
        </>
      ) : (
        <>
          {
            heroImage && (
              <img
                src={heroImage}
                alt=""
                class="mb-8 max-h-[60vh] mx-auto w-auto rounded-md object-contain !border-0"
                loading="lazy"
              />
            )
          }
          <Content />
        </>
      )}
    </article>



    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 sm:my-8">
      {tags.map((tag) => <Tag tag={slugifyStr(tag)} tagName={tag} />)}
    </ul>

    <div
      class="flex flex-col items-center justify-between gap-6 sm:flex-row sm:items-end sm:gap-4"
    >
      <ShareLinks />

      <button
        id="back-to-top"
        class="focus-outline py-1 whitespace-nowrap hover:opacity-75"
      >
        <IconChevronLeft class="inline-block rotate-90" />
        <span>Back to Top</span>
      </button>
    </div>

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div 
      data-pagefind-ignore 
      class="flex flex-col sm:flex-row justify-between gap-6"
      data-prev-url={prevPost ? prevPost.path : ""}
      data-next-url={nextPost ? nextPost.path : ""}
    >
      {
        prevPost && (
          <a
            href={prevPost.path}
            class="flex gap-2 hover:opacity-75 items-start"
            id="prev-post-link"
          >
            <IconChevronLeft class="inline-block flex-shrink-0 mt-0.5" />
            <div class="min-w-0">
              <span class="block text-sm text-foreground/70">Previous Post</span>
              <div class="text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={nextPost.path}
            class="flex gap-2 hover:opacity-75 items-start justify-end text-right ml-auto"
            id="next-post-link"
          >
            <div class="min-w-0">
              <span class="block text-sm text-foreground/70">Next Post</span>
              <div class="text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-shrink-0 mt-0.5" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline type="module" data-astro-rerun define:vars={{ postDetailsRerunUrl }}>
  import(postDetailsRerunUrl).then(({ initPostDetails }) => initPostDetails());
</script>

<style>
  .youtube-embed-container {
    margin: 2rem 0;
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
  }

  .youtube-embed-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
