---
import {
  CAREER_TIMELINE_AWARDS,
  CAREER_TIMELINE_EDUCATION,
  CAREER_TIMELINE_EXPERIENCE,
  CAREER_TIMELINE_HUMANITARIAN_IMPACT,
  CAREER_TIMELINE_PROJECTS,
  CAREER_TIMELINE_PUBLICATIONS,
} from "@/data/careerTimelineData.ts";

---

<div class="timeline-sections space-y-16 mt-12 mb-16">
  {/* Publications Section */}
  <section id="publications" class="!p-0 !m-0 scroll-mt-24">
    <h2 class="text-2xl font-bold mb-8 border-b border-border pb-2 italic">Publications</h2>
    <div class="relative border-l-2 border-border ml-3 md:ml-4 space-y-12">
      {CAREER_TIMELINE_PUBLICATIONS.map((item) => (
        <div class="relative pl-8">
          <div class="absolute -left-[11px] top-1.5 w-5 h-5 rounded-full bg-background border-4 border-accent"></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-1">
            <h3 class="text-lg font-bold leading-tight">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-accent/30 underline-offset-4">
                  {item.title}
                </a>
              ) : (
                item.title
              )}
            </h3>
            <span class="text-sm font-semibold text-accent/80 whitespace-nowrap">{item.year}</span>
          </div>
          <p class="text-base text-foreground/80 mt-1">
            <span
              set:html={(item.description ?? "").replace(
                /\*\*Flandre N\.\*\*/g,
                "<strong>Flandre N.</strong>"
              )}
            />.
            <span class="italic"> {item.subtitle}</span>
          </p>
        </div>
      ))}
    </div>
  </section>

  {/* Experience Section */}
  <section id="experience" class="!p-0 !m-0 scroll-mt-24">
    <h2 class="text-2xl font-bold mb-8 border-b border-border pb-2 italic">Experience</h2>
    <div class="relative border-l-2 border-border ml-3 md:ml-4 space-y-12">
      {CAREER_TIMELINE_EXPERIENCE.map((item) => (
        <div class="relative pl-8">
          <div class="absolute -left-[11px] top-1.5 w-5 h-5 rounded-full bg-background border-4 border-accent"></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-1">
            <h3 class="text-xl font-bold leading-tight">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-accent/30 underline-offset-4">
                  {item.title} {item.subtitle && `— ${item.subtitle}`}
                </a>
              ) : (
                `${item.title} ${item.subtitle ? `— ${item.subtitle}` : ""}`
              )}
            </h3>
            <span class="text-sm font-semibold text-accent/80 whitespace-nowrap">{item.year}</span>
          </div>
          {item.location && <p class="text-sm text-foreground/50 italic mb-2">{item.location}</p>}
          {item.description && <p class="text-base font-medium text-foreground/80 mb-2 italic">{item.description}</p>}
          {item.body && <p class="text-base text-foreground/70 mb-2" set:html={item.body} />}
          {item.details && (
            <ul class="list-disc list-outside ml-4 space-y-1 text-base text-foreground/70">
              {item.details.map(detail => <li set:html={detail} />)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  {/* Education Section */}
  <section id="education" class="!p-0 !m-0 scroll-mt-24">
    <h2 class="text-2xl font-bold mb-8 border-b border-border pb-2 italic">Education</h2>
    <div class="relative border-l-2 border-border ml-3 md:ml-4 space-y-12">
      {CAREER_TIMELINE_EDUCATION.map((item) => (
        <div class="relative pl-8">
          <div class="absolute -left-[11px] top-1.5 w-5 h-5 rounded-full bg-background border-4 border-accent"></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-1">
            <h3 class="text-xl font-bold leading-tight">{item.title} {item.subtitle && `— ${item.subtitle}`}</h3>
            <span class="text-sm font-semibold text-accent/80 whitespace-nowrap">{item.year}</span>
          </div>
          {item.location && <p class="text-sm text-foreground/50 italic mb-2">{item.location}</p>}
          {item.description && <p class="text-base text-foreground/80 mb-2">{item.description}</p>}
          {item.details && (
            <ul class="list-dash list-outside ml-4 space-y-1 text-base text-foreground/70">
              {item.details.map(detail => <li set:html={detail} />)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  {/* Projects Section */}
  <section id="projects" class="!p-0 !m-0 scroll-mt-24">
    <h2 class="text-2xl font-bold mb-8 border-b border-border pb-2 italic">Projects</h2>
    <div class="relative border-l-2 border-border ml-3 md:ml-4 space-y-12">
      {CAREER_TIMELINE_PROJECTS.map((item) => (
        <div class="relative pl-8">
          <div class="absolute -left-[11px] top-1.5 w-5 h-5 rounded-full bg-background border-4 border-accent"></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-1">
            <h3 class="text-xl font-bold leading-tight">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-accent/30 underline-offset-4">
                  {item.title}
                </a>
              ) : (
                item.title
              )}
            </h3>
            <span class="text-sm font-semibold text-accent/80 whitespace-nowrap">{item.year}</span>
          </div>
          {item.description && <p class="text-base text-foreground/80 mt-2">{item.description}</p>}
        </div>
      ))}
    </div>
  </section>

  {/* Awards Section */}
  <section id="awards" class="!p-0 !m-0 scroll-mt-24">
    <h2 class="text-2xl font-bold mb-8 border-b border-border pb-2 italic">Awards</h2>
    <div class="relative border-l-2 border-border ml-3 md:ml-4 space-y-12">
      {CAREER_TIMELINE_AWARDS.map((item) => (
        <div class="relative pl-8">
          <div class="absolute -left-[11px] top-1.5 w-5 h-5 rounded-full bg-background border-4 border-accent"></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-1">
            <h3 class="text-xl font-bold leading-tight">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-accent/30 underline-offset-4">
                  {item.title}
                </a>
              ) : (
                item.title
              )}
            </h3>
            <span class="text-sm font-semibold text-accent/80 whitespace-nowrap">{item.year}</span>
          </div>
          {item.location && <p class="text-sm text-foreground/50 italic mb-2">{item.location}</p>}
          {item.details && (
            <ul class="list-disc list-outside ml-4 space-y-1 text-base text-foreground/70">
              {item.details.map(detail => <li>{detail}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  {/* Humanitarian Impact Section */}
  <section id="humanitarian-impact" class="!p-0 !m-0 scroll-mt-24">
    <h2 class="text-2xl font-bold mb-8 border-b border-border pb-2 italic">Humanitarian Impact</h2>
    <div class="relative border-l-2 border-border ml-3 md:ml-4 space-y-12">
      {CAREER_TIMELINE_HUMANITARIAN_IMPACT.map((item) => (
        <div class="relative pl-8">
          <div class="absolute -left-[11px] top-1.5 w-5 h-5 rounded-full bg-background border-4 border-accent"></div>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-1">
            <h3 class="text-xl font-bold leading-tight">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-accent underline decoration-accent/30 underline-offset-4">
                  {item.title} {item.subtitle && `— ${item.subtitle}`}
                </a>
              ) : (
                `${item.title} ${item.subtitle ? `— ${item.subtitle}` : ""}`
              )}
            </h3>
            <span class="text-sm font-semibold text-accent/80 whitespace-nowrap">{item.year}</span>
          </div>
          {item.location && <p class="text-sm text-foreground/50 italic mb-2">{item.location}</p>}
          {item.description && <p class="text-base font-medium text-foreground/80 mb-2 italic">{item.description}</p>}
          {item.details && (
            <ul class="list-disc list-outside ml-4 space-y-1 text-base text-foreground/70">
              {item.details.map(detail => <li>{detail}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>
</div>

<style>
  .list-dash {
    list-style-type: "- ";
  }
</style>
