---
import { type CollectionEntry, getCollection } from "astro:content";
import PostDetails from "@/layouts/PostDetails.astro";
import { isListedPost, isUnlistedPost } from "@/features/blog/utils/postFilter";
import { getPostStaticPathParams } from "@/features/blog/utils/staticPaths";
import getSortedPosts from "@/features/blog/utils/getSortedPosts";

export interface Props {
  post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => isListedPost(data));
  const postResult = posts.map((post) => ({
    params: getPostStaticPathParams(post),
    props: { post },
  }));

  // Also include unlisted posts so they can be accessed via direct URL
  const unlistedPosts = await getCollection("blog", ({ data }) => isUnlistedPost(data));
  const unlistedResult = unlistedPosts.map((post) => ({
    params: getPostStaticPathParams(post),
    props: { post },
  }));

  return [...postResult, ...unlistedResult];
}

const { post } = Astro.props;

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
---

<PostDetails post={post} posts={sortedPosts} />
